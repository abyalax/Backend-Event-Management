meta {
  name: Login - Password Does Not Match
  type: http
  seq: 4
}

post {
  url: {{URL_API}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "admin@gmail.com",
    "password": "password_wrong"
  }
}

vars:pre-request {
  URL_API: http://localhost:4000
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Example case email does not found
}
