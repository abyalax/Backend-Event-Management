meta {
  name: Login - Success
  type: http
  seq: 1
}

post {
  url: {{URL_API}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "admin@gmail.com",
    "password": "password"
  }
}

vars:pre-request {
  api_url: http://localhost:4000
}

settings {
  encodeUrl: true
  timeout: 0
}
