meta {
  name: Create QRIS Payment
  type: http
  seq: 3
}

post {
  url: "{{baseUrl}}/payments/qris"
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{authToken}}
}

body:json {
  {
    "referenceId": "QR-{{$randomUUID}}",
    "amount": 75000,
    "currency": "IDR"
  }
}
