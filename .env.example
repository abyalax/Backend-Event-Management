DATABASE_URL=postgresql://root:postgress_pass@localhost:5433/db_event_management
DATABASE_TYPE=postgres

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_password

# PostgreSQL Configuration
POSTGRES_USER=root
POSTGRES_PASSWORD=postgress_pass
POSTGRES_DB=db_event_management

# MinIO Configuration
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

JWT_SECRET=jwt_secret
JWT_PRIVATE_KEY=jwt_private_key
JWT_PUBLIC_KEY=jwt_public_key
JWT_EXPIRATION=jwt_expiration
JWT_REFRESH_SECRET=jwt_refresh_secret
JWT_REFRESH_EXPIRATION=jwt_refresh_expiration

COOKIE_SECRET=cookie_secret

PORT=4000

# MinIO CONFIGURATION

# MinIO Server Endpoint
MINIO_ENDPOINT=localhost
MINIO_PORT=9000

# Use SSL/TLS (true for production)
MINIO_USE_SSL=false

# MinIO Credentials
# SECURITY: Use strong credentials in production
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# MinIO Region
MINIO_REGION=us-east-1

NODE_TLS_REJECT_UNAUTHORIZED=0

# MAILPIT CONFIGURATION
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
MAILPIT_SECURE=false
MAILPIT_USER=evenic-mailpit
MAILPIT_PASSWORD=evenic-mailpit
MAILPIT_FROM_EMAIL=evenics@vest.com
MAILPIT_FROM_NAME=Evenics

# MailPit Docker Configuration
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAILPIT_MAX_MESSAGES=1000
MAILPIT_SMTP_AUTH_ACCEPT_ANY=true


# BUCKET CONFIGURATION
# Each bucket is automatically created on application startup

# Bucket untuk documents (PDF, Word, Excel, etc)
STORAGE_BUCKET_DOCUMENTS=documents

# Bucket untuk images (JPG, PNG, WebP, etc)
STORAGE_BUCKET_IMAGES=images

# Bucket untuk public images (banners, posters, etc)
STORAGE_BUCKET_IMAGES_PUBLIC=images-public

# Bucket untuk backups dan archives
STORAGE_BUCKET_BACKUPS=backups

# Bucket untuk video files (MP4, WebM, etc)
STORAGE_BUCKET_VIDEOS=videos

# Bucket untuk public ticket PDFs
STORAGE_BUCKET_TICKETS_PUBLIC=tickets-public


# FILE CONSTRAINTS

# Maximum file size in bytes (default: 50MB)
# Common sizes:
#   10MB    = 10485760
#   50MB    = 52428800
#   100MB   = 104857600
#   500MB   = 524288000
#   1GB     = 1073741824
MAX_FILE_SIZE=52428800

# Allowed MIME types (comma-separated)
# Leave empty to allow all types
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf,video/mp4

# RETRY STRATEGY CONFIGURATION
# Automatic retry dengan exponential backoff untuk handle transient failures

# Maximum retry attempts
# Recommended: 3-5 (development), 5-7 (production)
RETRY_MAX_ATTEMPTS=3

# Initial delay dalam milliseconds
# First retry waits this long, then doubles each time
RETRY_INITIAL_DELAY_MS=100

# Maximum delay dalam milliseconds
# Delay won't exceed this value even with exponential backoff
RETRY_MAX_DELAY_MS=5000

# MONITORING & OBSERVABILITY

# Enable storage metrics collection
ENABLE_STORAGE_METRICS=true

# Health check interval dalam milliseconds
# How often to check MinIO health status
STORAGE_HEALTH_CHECK_INTERVAL=30000

# APPLICATION CONFIGURATION

# Node environment
NODE_ENV=development

# Log level (debug, log, warn, error, fatal)
LOG_LEVEL=debug

# SECURITY & AUTHENTICATION (OPTIONAL)

# JWT configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24h

# CORS configuration
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# DEVELOPMENT ENVIRONMENT (.env.development)
# Used when NODE_ENV=development

# Use local MinIO instance
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Disable SSL verification untuk development
NODE_TLS_REJECT_UNAUTHORIZED=0

# Increased logging
LOG_LEVEL=debug

# PRODUCTION ENVIRONMENT (.env.production)
# NEVER commit production credentials to git!
# Use secure secret management (AWS Secrets Manager, HashiCorp Vault, etc)

# Example production setup:
# MINIO_ENDPOINT=minio.production.com
# MINIO_PORT=9000
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=${AWS_SECRETS_MANAGER_ACCESS_KEY}
# MINIO_SECRET_KEY=${AWS_SECRETS_MANAGER_SECRET_KEY}
# MINIO_REGION=ap-southeast-1

# Increased retry attempts untuk stability
# RETRY_MAX_ATTEMPTS=5
# RETRY_INITIAL_DELAY_MS=200
# RETRY_MAX_DELAY_MS=10000

# Disable debug logging
# LOG_LEVEL=warn

# Production database (RDS, etc)
# DATABASE_URL=postgresql://prod_user:${DB_PASSWORD}@rds.amazonaws.com:5432/prod_db

# TESTING ENVIRONMENT (.env.test)
# Used when running tests

# Test MinIO (using testcontainers or mock)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=19000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=test
# MINIO_SECRET_KEY=test

# Fast retry untuk tests
# RETRY_MAX_ATTEMPTS=1
# RETRY_INITIAL_DELAY_MS=10
# RETRY_MAX_DELAY_MS=100

# In-memory database untuk tests
# DATABASE_URL=sqlite::memory:

# NOTES

# 1. SECURITY BEST PRACTICES:
#    - Never commit .env to git (add to .gitignore)
#    - Use environment variables untuk sensitive data
#    - Rotate credentials regularly
#    - Use strong passwords (>16 chars dengan symbols)

# 2. FILE SIZE SETTINGS:
#    - Default 50MB suitable untuk documents & images
#    - Increase for video files (500MB-1GB)
#    - Consider client upload limits
#    - Set rate limiting untuk large uploads

# 3. RETRY CONFIGURATION:
#    - Development: 3 attempts, lower delays
#    - Production: 5-7 attempts, higher delays
#    - Adjust based on network reliability
#    - Too many retries = longer failures

# 4. MINIO SETUP:
#    - Development: use docker-compose (provided)
#    - Production: use managed service atau cluster
#    - Always use SSL (MINIO_USE_SSL=true)
#    - Configure proper IAM policies

# 5. MONITORING:
#    - Enable ENABLE_STORAGE_METRICS=true
#    - Setup log aggregation (ELK, CloudWatch)
#    - Configure alerting untuk failures
#    - Regular health check monitoring

# 6. PERFORMANCE TUNING:
#    - Increase RETRY_MAX_DELAY_MS untuk unstable networks
#    - Configure connection pool size
#    - Use CDN untuk frequent downloads
#    - Enable compression untuk suitable MIME types

